# App
APP_ENV=local
APP_NAME=Sessions Marketplace
APP_URL=http://localhost
NGINX_HTTP_PORT=80

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:3000

# PostgreSQL
POSTGRES_DB=sessions_marketplace
POSTGRES_USER=sessions_user
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgres://sessions_user:replace-with-a-strong-password@db:5432/sessions_marketplace
TEST_DATABASE_URL=sqlite:///test.sqlite3

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Google OAuth2
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost/auth/google/callback

# Razorpay test mode
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace-with-razorpay-test-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret

# S3-compatible storage via MinIO
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=session-images
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_CUSTOM_DOMAIN=localhost:9000/session-images
AWS_S3_ADDRESSING_STYLE=path
AWS_S3_USE_SSL=False
AWS_S3_SECURE_URLS=False
AWS_DEFAULT_ACL=private
BOOTSTRAP_MINIO=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost/api
NEXT_PUBLIC_APP_URL=http://localhost
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace-with-google-client-id
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_replace_me
INTERNAL_API_BASE_URL=http://backend:8000/api

# Docker build targets
BACKEND_DOCKER_TARGET=runtime
FRONTEND_DOCKER_TARGET=runner

# Rate limiting
AUTH_RATE_LIMIT=5/minute
PAYMENT_RATE_LIMIT=10/minute
DEFAULT_RATE_LIMIT=100/minute
DEFAULT_USER_RATE_LIMIT=1000/minute
